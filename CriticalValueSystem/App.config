	  <add key="UpdateCheckUrl" value="http://172.16.22.7:8090/prod-api/critical/versions/getInfoUpdate"/>
	  <!-- <add key="UpdateCheckUrl" value="D:\UpdateTest\version.json"/>-->
	  <add key="UpdaterExecutableName" value="Updater.exe"/>
	  <add key="ClientSettingsProvider.ServiceUri" value=""/>
      <add key="ReminderInterval" value="60000"/> <!-- 提醒间隔，单位：毫秒，默认为10分钟 -->	  
	  
	  <!--CA参数-->
	  <!--日志保存路径-->
	  <add key="LogPath" value="C:\\Appsoft\\Calog\\"/>
	  <!--日志记录级别 0、不记录日志，1、记录错误日期，2、记录警告日志，3、普通日志，4、出入参日志-->
	  <add key="LogLever" value="4"/>
