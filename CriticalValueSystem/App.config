	  <!--End-->
	  <!--医护端签名参数-->
	  <!--CA服务端地址-->
	  <add key="Url" value="http://172.16.2.47:10201/coss/service/v1/"/>
	  <!--APPID-->
	  <add key="AppID" value="APP_9CAE9875B346410399FD3F29B05F952B"/>
	  <!--密钥-->
	  <add key="Key" value="OWU0NjE2YzY1ZWNkNGZhYTkzOTQyZmFiZDA4YzNkNWM="/>
	  <!--免验证签名有效时间，单位：分钟-->
	  <add key="exemptTime" value="720"/>
	  <!--时效签有效时间，单位：秒，最大 86400 ，即24小时-->
	  <add key="TimeRegion" value="43200"/>
	  <!--认证签名有效时间，单位：分钟，最大 4320 ，即3天-->
	  <add key="ExpiryDate" value="3"/>
	  <!--是否自动开启免验签 0、不开启，需要手工选择，1、自动开启，2、不使用免验签-->
	  <add key="autoSign" value="0"/>
	  <!--可以使用的证书类型，0、都使用，1、KEY证书，2、APP证书-->
	  <add key="certType" value="0"/>
	  <!--End-->	  
	  
	  
  </appSettings>
  <system.web>
    <membership defaultProvider="ClientAuthenticationMembershipProvider">
      <providers>
        <add name="ClientAuthenticationMembershipProvider" type="System.Web.ClientServices.Providers.ClientFormsAuthenticationMembershipProvider, System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" serviceUri=""/>
      </providers>
    </membership>
    <roleManager defaultProvider="ClientRoleProvider" enabled="true">
      <providers>
        <add name="ClientRoleProvider" type="System.Web.ClientServices.Providers.ClientRoleProvider, System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" serviceUri="" cacheTimeout="86400"/>
      </providers>
    </roleManager>
  </system.web>
</configuration>
